enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELED
}

model Booking {
  id        String        @id @default(uuid())
  user      User          @relation(fields: [userId], references: [id])
  userId    String
  table     Table         @relation(fields: [tableId], references: [id])
  tableId   String
  status    BookingStatus @default(PENDING)
  startAt   DateTime
  endAt     DateTime
  createdAt DateTime      @default(now())
}
